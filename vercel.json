{
  "version": 2,
  "buildCommand": "npm install --prefix backend",
  "installCommand": "npm install --prefix backend",
  "env": {
    "PORT": "3000"
  },
  "functions": {
    "backend/src/server.js": {
      "runtime": "nodejs"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/server.js",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "backend/src/server.js"
    }
  ]
}
